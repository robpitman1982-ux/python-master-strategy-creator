from __future__ import annotations\par
\par
from itertools import combinations\par
from typing import List, Type\par
\par
\par
def generate_filter_combinations(\par
    filter_classes: list[Type],\par
    min_filters: int = 3,\par
    max_filters: int = 5,\par
) -> list[list[Type]]:\par
    """\par
    Generate combinations of filter classes.\par
\par
    Example:\par
        [Trend, Pullback, Recovery, Volatility, Momentum]\par
    ->\par
        [\par
            [Trend, Pullback, Recovery],\par
            [Trend, Pullback, Recovery, Volatility],\par
            ...\par
        ]\par
    """\par
    if not filter_classes:\par
        return []\par
\par
    combos: list[list[Type]] = []\par
\par
    max_filters = min(max_filters, len(filter_classes))\par
\par
    for r in range(min_filters, max_filters + 1):\par
        for combo in combinations(filter_classes, r):\par
            combos.append(list(combo))\par
\par
    return combos\par
\par
\par
def build_filter_combo_name(filter_objects: list) -> str:\par
    """\par
    Create a readable short name for a filter set.\par
    """\par
    if not filter_objects:\par
        return "NoFilters"\par
\par
    parts: List[str] = []\par
    for filter_obj in filter_objects:\par
        name = getattr(filter_obj, "name", filter_obj.__class__.__name__)\par
        short_name = name.replace("Filter", "")\par
        parts.append(short_name)\par
\par
    return "_".join(parts)\par
