class OptimizationHeatmap:\par
    """\par
    Generates pivot-table heatmaps from optimizer results.\par
    Used to visualize parameter plateaus.\par
    """\par
\par
    def __init__(self, optimization_df: pd.DataFrame):\par
        if optimization_df is None or optimization_df.empty:\par
            raise ValueError("Optimization dataframe is empty.")\par
\par
        self.df = optimization_df.copy()\par
\par
    def create_heatmap(\par
        self,\par
        metric: str,\par
        index_param: str = "hold_bars",\par
        column_param: str = "stop_distance_points",\par
    ) -> pd.DataFrame:\par
        """\par
        Creates pivot heatmap for chosen metric.\par
        """\par
\par
        if metric not in self.df.columns:\par
