from __future__ import annotations\par
\par
from dataclasses import dataclass\par
from typing import Optional\par
\par
import numpy as np\par
import pandas as pd\par
\par
\par
@dataclass\par
class EngineConfig:\par
    # Global Presets from Master Prompt\par
    initial_capital: float = 250_000.0\par
    risk_per_trade: float = 0.01\par
    symbol: str = "ES"\par
\par
    # Friction Assumptions\par
    commission_per_contract: float = 2.00\par
    slippage_ticks: int = 4\par
    tick_value: float = 12.50\par
    dollars_per_point: float = 50.0\par
\par
\par
@dataclass\par
class Trade:\par
    entry_time: pd.Timestamp\par
    exit_time: pd.Timestamp\par
    direction: str\par
    entry_price: float\par
    exit_price: float\par
    contracts: int\par
    pnl: float\par
    bars_held: int\par
    exit_reason: str\par
    mae_points: float\par
    mfe_points: float\par
\par
\par
class MasterStrategyEngine:\par
    def __init__(self, data: pd.DataFrame, config: Optional[EngineConfig] = None):\par
        if data is None or data.empty:\par
            raise ValueError("Data is empty. Cannot initialize engine.")\par
\par
        self.data = data.copy()\par
        self.config = config or EngineConfig()\par
\par
        self.initial_capital = float(self.config.initial_capital)\par
        self.current_capital = float(self.config.initial_capital)\par
        self.risk_per_trade = float(self.config.risk_per_trade)\par
\par
        self.position: Optional[dict] = None\par
        self.trades: list[Trade] = []\par
        self.equity_curve: list[dict] = []\par
        self.strategy_name: str = "UnknownStrategy"\par
\par
    def calculate_position_size_contracts(\par
        self,\par
        stop_distance_points: float,\par
        dollars_per_point: Optional[float] = None,\par
    ) -> int:\par
        if dollars_per_point is None:\par
            dollars_per_point = self.config.dollars_per_point\par
\par
        if stop_distance_points <= 0 or dollars_per_point <= 0:\par
            return 0\par
\par
        risk_amount = self.current_capital * self.risk_per_trade\par
        contracts_float = risk_amount / (stop_distance_points * dollars_per_point)\par
        contracts = int(np.floor(contracts_float))\par
\par
        return max(1, contracts) if contracts > 0 else 0\par
\par
    def _close_position(\par
        self,\par
        exit_time: pd.Timestamp,\par
        exit_price: float,\par
        bars_held: int,\par
        exit_reason: str,\par
    ) -> None:\par
        entry_price = self.position["entry_price"]\par
        contracts = self.position["contracts"]\par
\par
        gross_pnl = (exit_price - entry_price) * self.config.dollars_per_point * contracts\par
        commission_cost = contracts * self.config.commission_per_contract * 2.0\par
        net_pnl = gross_pnl - commission_cost\par
\par
        self.current_capital += net_pnl\par
\par
        trade = Trade(\par
            entry_time=self.position["entry_time"],\par
            exit_time=exit_time,\par
            direction="LONG",\par
            entry_price=entry_price,\par
            exit_price=exit_price,\par
            contracts=contracts,\par
            pnl=net_pnl,\par
            bars_held=bars_held,\par
            exit_reason=exit_reason,\par
            mae_points=float(self.position["mae_points"]),\par
            mfe_points=float(self.position["mfe_points"]),\par
        )\par
        self.trades.append(trade)\par
        self.position = None\par
\par
    def _update_open_position_excursions(self, bar_low: float, bar_high: float) -> None:\par
        if self.position is None:\par
            return\par
\par
        entry_price = self.position["entry_price"]\par
\par
        adverse_excursion = bar_low - entry_price\par
        favorable_excursion = bar_high - entry_price\par
\par
        self.position["mae_points"] = min(self.position["mae_points"], adverse_excursion)\par
        self.position["mfe_points"] = max(self.position["mfe_points"], favorable_excursion)\par
\par
    def run(\par
        self,\par
        strategy,\par
        hold_bars: Optional[int] = None,\par
        stop_distance_points: Optional[float] = None,\par
    ) -> None:\par
        if len(self.data) < 2:\par
            raise ValueError("Not enough data to run backtest.")\par
\par
        self.position = None\par
        self.trades = []\par
        self.equity_curve = []\par
        self.current_capital = float(self.initial_capital)\par
        self.strategy_name = getattr(strategy, "name", "UnknownStrategy")\par
\par
        if hold_bars is None:\par
            hold_bars = getattr(strategy, "hold_bars", 3)\par
\par
        if stop_distance_points is None:\par
            stop_distance_points = getattr(strategy, "stop_distance_points", 10.0)\par
\par
        slippage_points = self.config.slippage_ticks * (\par
            self.config.tick_value / self.config.dollars_per_point\par
        )\par
\par
        for i in range(len(self.data)):\par
            bar = self.data.iloc[i]\par
            timestamp = self.data.index[i]\par
            close_price = float(bar["close"])\par
            low_price = float(bar["low"])\par
            high_price = float(bar["high"])\par
\par
            self.equity_curve.append(\par
                \{\par
                    "datetime": timestamp,\par
                    "equity": self.current_capital,\par
                \}\par
            )\par
\par
            if self.position is not None:\par
                bars_held = i - self.position["entry_index"]\par
\par
                self._update_open_position_excursions(\par
                    bar_low=low_price,\par
                    bar_high=high_price,\par
                )\par
\par
                stop_price = self.position["stop_price"]\par
\par
                if low_price <= stop_price:\par
                    stop_exit_price = stop_price - (slippage_points / 2.0)\par
                    self._close_position(\par
                        exit_time=timestamp,\par
                        exit_price=stop_exit_price,\par
                        bars_held=bars_held,\par
                        exit_reason="STOP",\par
                    )\par
                    continue\par
\par
                if bars_held >= hold_bars:\par
                    time_exit_price = close_price - (slippage_points / 2.0)\par
                    self._close_position(\par
                        exit_time=timestamp,\par
                        exit_price=time_exit_price,\par
                        bars_held=bars_held,\par
                        exit_reason="TIME",\par
                    )\par
                    continue\par
\par
            if self.position is None:\par
                signal = strategy.generate_signal(self.data, i)\par
\par
                if signal == 1:\par
                    contracts = self.calculate_position_size_contracts(\par
                        stop_distance_points=stop_distance_points\par
                    )\par
\par
                    if contracts > 0:\par
                        entry_price = close_price + (slippage_points / 2.0)\par
                        stop_price = entry_price - stop_distance_points\par
\par
                        self.position = \{\par
                            "entry_index": i,\par
                            "entry_time": timestamp,\par
                            "entry_price": entry_price,\par
                            "stop_price": stop_price,\par
                            "contracts": contracts,\par
                            "mae_points": 0.0,\par
                            "mfe_points": 0.0,\par
                        \}\par
\par
        if self.position is not None:\par
            final_bar = self.data.iloc[-1]\par
            final_time = self.data.index[-1]\par
            final_close = float(final_bar["close"])\par
            final_low = float(final_bar["low"])\par
            final_high = float(final_bar["high"])\par
            bars_held = len(self.data) - 1 - self.position["entry_index"]\par
\par
            self._update_open_position_excursions(\par
                bar_low=final_low,\par
                bar_high=final_high,\par
            )\par
\par
            final_exit_price = final_close - (slippage_points / 2.0)\par
            self._close_position(\par
                exit_time=final_time,\par
                exit_price=final_exit_price,\par
                bars_held=bars_held,\par
                exit_reason="FINAL_BAR",\par
            )\par
\par
    def trades_dataframe(self) -> pd.DataFrame:\par
        if not self.trades:\par
            return pd.DataFrame()\par
\par
        return pd.DataFrame(\par
            [\par
                \{\par
                    "entry_time": t.entry_time,\par
                    "exit_time": t.exit_time,\par
                    "direction": t.direction,\par
                    "entry_price": t.entry_price,\par
                    "exit_price": t.exit_price,\par
                    "contracts": t.contracts,\par
                    "pnl": t.pnl,\par
                    "bars_held": t.bars_held,\par
                    "exit_reason": t.exit_reason,\par
                    "mae_points": t.mae_points,\par
                    "mfe_points": t.mfe_points,\par
                \}\par
                for t in self.trades\par
            ]\par
        )\par
\par
    def equity_curve_dataframe(self) -> pd.DataFrame:\par
        if not self.equity_curve:\par
            return pd.DataFrame()\par
\par
        return pd.DataFrame(self.equity_curve)\par
\par
    def _calculate_max_drawdown(self) -> float:\par
        equity_df = self.equity_curve_dataframe()\par
        if equity_df.empty or "equity" not in equity_df.columns:\par
            return 0.0\par
\par
        running_peak = equity_df["equity"].cummax()\par
        drawdown = equity_df["equity"] - running_peak\par
        max_drawdown = float(drawdown.min())\par
\par
        return max_drawdown\par
\par
    def results(self) -> dict:\par
        total_pnl = self.current_capital - self.initial_capital\par
        total_trades = len(self.trades)\par
\par
        gross_profit = sum(t.pnl for t in self.trades if t.pnl > 0)\par
        gross_loss = sum(t.pnl for t in self.trades if t.pnl < 0)\par
        net_pnl = gross_profit + gross_loss\par
\par
        wins = sum(1 for t in self.trades if t.pnl > 0)\par
        losses = sum(1 for t in self.trades if t.pnl <= 0)\par
        win_rate = (wins / total_trades * 100.0) if total_trades > 0 else 0.0\par
        average_trade = (net_pnl / total_trades) if total_trades > 0 else 0.0\par
\par
        if gross_loss != 0:\par
            profit_factor = gross_profit / abs(gross_loss)\par
        else:\par
            profit_factor = 0.0\par
\par
        max_drawdown = self._calculate_max_drawdown()\par
\par
        exit_reason_counts: dict[str, int] = \{\}\par
        for trade in self.trades:\par
            exit_reason_counts[trade.exit_reason] = exit_reason_counts.get(trade.exit_reason, 0) + 1\par
\par
        average_mae = (\par
            sum(t.mae_points for t in self.trades) / total_trades\par
            if total_trades > 0\par
            else 0.0\par
        )\par
        average_mfe = (\par
            sum(t.mfe_points for t in self.trades) / total_trades\par
            if total_trades > 0\par
            else 0.0\par
        )\par
\par
        return \{\par
            "Strategy": self.strategy_name,\par
            "Symbol": self.config.symbol,\par
            "Initial Capital": f"$\{self.initial_capital:,.2f\}",\par
            "Current Capital": f"$\{self.current_capital:,.2f\}",\par
            "Net PnL": f"$\{total_pnl:,.2f\}",\par
            "Gross Profit": f"$\{gross_profit:,.2f\}",\par
            "Gross Loss": f"$\{gross_loss:,.2f\}",\par
            "Average Trade": f"$\{average_trade:,.2f\}",\par
            "Profit Factor": f"\{profit_factor:.2f\}",\par
            "Max Drawdown": f"$\{max_drawdown:,.2f\}",\par
            "Average MAE (pts)": f"\{average_mae:.2f\}",\par
            "Average MFE (pts)": f"\{average_mfe:.2f\}",\par
            "Total Trades": total_trades,\par
            "Wins": wins,\par
            "Losses": losses,\par
            "Win Rate": f"\{win_rate:.2f\}%",\par
            "Exit Reasons": exit_reason_counts,\par
        \}\par
\par
