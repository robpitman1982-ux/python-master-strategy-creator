    def run_family_filter_combination_sweep(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        return self.run_filter_combination_sweep(\par
            data=data,\par
            cfg=cfg,\par
            max_workers=max_workers,\par
        )\par
\par
    def run_refinement_for_candidate(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        candidate_row: dict[str, Any],\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        active_grid = self.get_refinement_grid_for_candidate(candidate_row)\par
        trade_filters = self.get_trade_filter_thresholds()\par
        promoted_combo_classes = candidate_row.get("filter_classes", [])\par
\par
        def strategy_factory(\par
            hold_bars: int,\par
            stop_distance_points: float,\par
            min_avg_range: float,\par
            momentum_lookback: int,\par
        ):\par
            return self.build_candidate_specific_strategy(\par
                promoted_combo_classes=promoted_combo_classes,\par
                hold_bars=hold_bars,\par
                stop_distance_points=stop_distance_points,\par
                min_avg_range=min_avg_range,\par
                momentum_lookback=momentum_lookback,\par
            )\par
\par
        refiner = StrategyParameterRefiner(\par
            engine_class=MasterStrategyEngine,\par
            data=data,\par
            strategy_factory=strategy_factory,\par
            config=cfg,\par
        )\par
\par
        print("\\n\f2\u-10180?\u-8273?\f0  Running top-combo parameter refinement...")\par
        refinement_df = refiner.run_refinement(\par
            hold_bars=active_grid["hold_bars"],\par
            stop_distance_points=active_grid["stop_distance_points"],\par
            min_avg_range=active_grid["min_avg_range"],\par
            momentum_lookback=active_grid["momentum_lookback"],\par
            min_trades=trade_filters["min_trades"],\par
            min_trades_per_year=trade_filters["min_trades_per_year"],\par
            parallel=True,\par
            max_workers=max_workers,\par
        )\par
\par
        if not refinement_df.empty:\par
            print(f"\\n\f2\u-10180?\u-8273?\f0  Top \{self.name\} Refinement Results:")\par
            print(refiner.top_results(10))\par
            refiner.print_summary_report(top_n=10)\par
\par
            plateau = PlateauAnalyzer(refinement_df)\par
            plateau.print_report(top_n=10)\par
\par
            output_path = Path("Outputs") / f"\{self.name\}_top_combo_refinement_results_narrow.csv"\par
            saved_path = refiner.save_results_csv(output_path)\par
            print(f"\\n\f2\u-10179?\u-9026?\f0  Narrow top-combo refinement saved to: \{saved_path\}")\par
        else:\par
            print("\\nNo refinement results met the trade filters.")\par
\par
        return refinement_df\par
\par
    def run_top_combo_refinement(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        candidate_row: dict[str, Any],\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        return self.run_refinement_for_candidate(\par
            data=data,\par
            cfg=cfg,\par
            candidate_row=candidate_row,\par
            max_workers=max_workers,\par
        )\par
\par
    def get_refinement_parameter_labels(self) -> dict[str, str]:\par
        return \{\par
            "hold_bars": "hold_bars",\par
            "stop_distance_points": "stop_distance_points",\par
            "min_avg_range": "min_avg_range",\par
            "momentum_lookback": "momentum_lookback",\par
        \}\par
\par
    def get_family_summary_notes(\par
        self,\par
        promoted_df: pd.DataFrame,\par
        refinement_df: pd.DataFrame,\par
    ) -> str:\par
        if promoted_df.empty:\par
            return "No candidates passed the promotion gate."\par
\par
        if refinement_df.empty:\par
            return "At least one candidate passed promotion, but no refinement rows met the refinement trade filters."\par
