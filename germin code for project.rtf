    def run_filter_combination_sweep(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        filter_classes = self.get_filter_classes()\par
        combinations = generate_filter_combinations(\par
            filter_classes=filter_classes,\par
            min_filters=3,\par
            max_filters=len(filter_classes),\par
        )\par
\par
        print(f"\\n\f1\u-10178?\u-8726?\f0  Running \{self.name\} filter combination sweep...")\par
        print(f"Total filter combinations: \{len(combinations)\}")\par
        print(f"Parallel mode: ON | max_workers=\{max_workers\}")\par
\par
        tasks = [(data, cfg, combo_classes) for combo_classes in combinations]\par
        results: list[dict[str, Any]] = []\par
\par
        with ProcessPoolExecutor(max_workers=max_workers) as executor:\par
            for idx, result in enumerate(executor.map(_run_mean_reversion_combo_case, tasks), start=1):\par
                print(f"  Combo \{idx\}/\{len(combinations)\} | \{result['strategy_name']\}")\par
                result["filter_classes"] = combinations[idx - 1]\par
                results.append(result)\par
\par
        results_df = pd.DataFrame(results)\par
\par
        if not results_df.empty:\par
            results_df = results_df.sort_values(\par
                by=["passes_trade_filter", "profit_factor", "average_trade", "net_pnl"],\par
                ascending=[False, False, False, False],\par
            ).reset_index(drop=True)\par
\par
        return results_df\par
