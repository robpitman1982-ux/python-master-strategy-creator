\par
from __future__ import annotations\par
\par
import pandas as pd\par
\par
\par
def add_precomputed_features(\par
    data: pd.DataFrame,\par
    sma_lengths: list[int] | None = None,\par
    avg_range_lookbacks: list[int] | None = None,\par
    momentum_lookbacks: list[int] | None = None,\par
) -> pd.DataFrame:\par
    """\par
    Add reusable precomputed feature columns to the OHLCV dataframe.\par
\par
    This reduces repeated rolling calculations during:\par
    - filter combination sweeps\par
    - parameter refinement\par
    """\par
\par
    df = data.copy()\par
\par
    sma_lengths = sma_lengths or []\par
    avg_range_lookbacks = avg_range_lookbacks or []\par
    momentum_lookbacks = momentum_lookbacks or []\par
\par
    # -----------------------------\par
    # Basic reusable columns\par
    # -----------------------------\par
    df["bar_range"] = df["high"] - df["low"]\par
    df["prev_close"] = df["close"].shift(1)\par
\par
    # -----------------------------\par
    # SMA columns\par
    # -----------------------------\par
    for length in sma_lengths:\par
        col = f"sma_\{length\}"\par
        if col not in df.columns:\par
            df[col] = df["close"].rolling(length).mean()\par
\par
    # -----------------------------\par
    # Average range columns\par
    # -----------------------------\par
    for lookback in avg_range_lookbacks:\par
        col = f"avg_range_\{lookback\}"\par
        if col not in df.columns:\par
            df[col] = df["bar_range"].rolling(lookback).mean()\par
\par
    # -----------------------------\par
    # Momentum columns\par
    # -----------------------------\par
    for lookback in momentum_lookbacks:\par
        diff_col = f"mom_diff_\{lookback\}"\par
        if diff_col not in df.columns:\par
            df[diff_col] = df["close"] - df["close"].shift(lookback)\par
\par
    return df\par
