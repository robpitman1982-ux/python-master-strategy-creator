from __future__ import annotations\par
\par
import os\par
import time\par
from collections import Counter\par
from concurrent.futures import ProcessPoolExecutor\par
from dataclasses import dataclass\par
from itertools import product\par
from pathlib import Path\par
from typing import Any, Callable\par
\par
import pandas as pd\par
\par
from modules.engine import EngineConfig\par
\par
\par
# -------------------------------------------------------------------\par
# Worker globals for parallel processing\par
# -------------------------------------------------------------------\par
_WORKER_ENGINE_CLASS = None\par
_WORKER_DATA = None\par
_WORKER_STRATEGY_FACTORY = None\par
_WORKER_CONFIG = None\par
\par
\par
def _parse_money(value: Any) -> float:\par
    if isinstance(value, (int, float)):\par
        return float(value)\par
\par
    text = str(value).replace("$", "").replace(",", "").strip()\par
    return float(text)\par
\par
\par
def _parse_percent(value: Any) -> float:\par
    if isinstance(value, (int, float)):\par
        return float(value)\par
\par
    text = str(value).replace("%", "").strip()\par
    return float(text)\par
\par
\par
def _calculate_years_in_sample(data: pd.DataFrame) -> float:\par
    if data.empty:\par
        return 0.0\par
\par
    start = data.index.min()\par
    end = data.index.max()\par
    total_days = (end - start).days\par
\par
    if total_days <= 0:\par
        return 0.0\par
\par
    return total_days / 365.25\par
\par
\par
def _init_refinement_worker(\par
    engine_class: type,\par
    data: pd.DataFrame,\par
    strategy_factory: Callable[..., Any],\par
    config: EngineConfig,\par
) -> None:\par
    global _WORKER_ENGINE_CLASS, _WORKER_DATA, _WORKER_STRATEGY_FACTORY, _WORKER_CONFIG\par
\par
    _WORKER_ENGINE_CLASS = engine_class\par
    _WORKER_DATA = data\par
    _WORKER_STRATEGY_FACTORY = strategy_factory\par
    _WORKER_CONFIG = config\par
\par
\par
def _run_refinement_case(task: dict[str, Any]) -> dict[str, Any]:\par
    strategy = _WORKER_STRATEGY_FACTORY(\par
        hold_bars=task["hold_bars"],\par
        stop_distance_points=task["stop_distance_points"],\par
        min_avg_range=task["min_avg_range"],\par
        momentum_lookback=task["momentum_lookback"],\par
    )\par
\par
    engine = _WORKER_ENGINE_CLASS(data=_WORKER_DATA, config=_WORKER_CONFIG)\par
    engine.run(strategy=strategy)\par
    summary = engine.results()\par
\par
    total_trades = int(summary["Total Trades"])\par
    years_in_sample = float(task["years_in_sample"])\par
    trades_per_year = total_trades / years_in_sample if years_in_sample > 0 else 0.0\par
\par
    passes_trade_filter = (\par
        total_trades >= task["min_trades"]\par
        and trades_per_year >= task["min_trades_per_year"]\par
    )\par
\par
    return \{\par
        "strategy_name": str(summary["Strategy"]),\par
        "hold_bars": int(task["hold_bars"]),\par
        "stop_distance_points": float(task["stop_distance_points"]),\par
        "min_avg_range": float(task["min_avg_range"]),\par
        "momentum_lookback": int(task["momentum_lookback"]),\par
        "total_trades": total_trades,\par
        "trades_per_year": trades_per_year,\par
        "passes_trade_filter": passes_trade_filter,\par
        "net_pnl": _parse_money(summary["Net PnL"]),\par
        "gross_profit": _parse_money(summary["Gross Profit"]),\par
        "gross_loss": _parse_money(summary["Gross Loss"]),\par
        "average_trade": _parse_money(summary["Average Trade"]),\par
        "profit_factor": float(summary["Profit Factor"]),\par
        "max_drawdown": _parse_money(summary["Max Drawdown"]),\par
        "win_rate": _parse_percent(summary["Win Rate"]),\par
        "average_mae_points": float(summary["Average MAE (pts)"]),\par
        "average_mfe_points": float(summary["Average MFE (pts)"]),\par
    \}\par
\par
\par
@dataclass\par
class RefinementResult:\par
    strategy_name: str\par
    hold_bars: int\par
    stop_distance_points: float\par
    min_avg_range: float\par
    momentum_lookback: int\par
    total_trades: int\par
    trades_per_year: float\par
    passes_trade_filter: bool\par
    net_pnl: float\par
    gross_profit: float\par
    gross_loss: float\par
    average_trade: float\par
    profit_factor: float\par
    max_drawdown: float\par
    win_rate: float\par
    average_mae_points: float\par
    average_mfe_points: float\par
\par
\par
class StrategyParameterRefiner:\par
    """\par
    Refines a chosen promising strategy/filter stack by sweeping a manageable\par
    grid of internal parameter values.\par
    """\par
\par
    def __init__(\par
        self,\par
        engine_class: type,\par
        data: pd.DataFrame,\par
        strategy_factory: Callable[..., Any],\par
        config: EngineConfig | None = None,\par
    ):\par
        self.engine_class = engine_class\par
        self.data = data\par
        self.strategy_factory = strategy_factory\par
        self.config = config or EngineConfig()\par
        self.results: list[RefinementResult] = []\par
\par
    def _default_max_workers(self) -> int:\par
        cpu_count = os.cpu_count() or 4\par
        return max(1, min(6, cpu_count - 2))\par
\par
    def run_refinement(\par
        self,\par
        hold_bars: list[int],\par
        stop_distance_points: list[float],\par
        min_avg_range: list[float],\par
        momentum_lookback: list[int],\par
        min_trades: int = 150,\par
        min_trades_per_year: float = 8.0,\par
        parallel: bool = True,\par
        max_workers: int | None = None,\par
    ) -> pd.DataFrame:\par
        self.results = []\par
\par
        years_in_sample = _calculate_years_in_sample(self.data)\par
        combinations = list(\par
            product(\par
                hold_bars,\par
                stop_distance_points,\par
                min_avg_range,\par
                momentum_lookback,\par
            )\par
        )\par
\par
        total_runs = len(combinations)\par
        accepted_count = 0\par
        rejected_count = 0\par
        start_time = time.perf_counter()\par
\par
        if max_workers is None:\par
            max_workers = self._default_max_workers()\par
\par
        print("\\n\f2\u-10180?\u-8273?\f5  Running top-combo parameter refinement...")\par
        print(f"Total combinations: \{total_runs\}")\par
        print(f"Years in sample: \{years_in_sample:.2f\}")\par
        print(\par
            f"Trade filters: min_trades=\{min_trades\}, "\par
            f"min_trades_per_year=\{min_trades_per_year:.2f\}"\par
        )\par
        print(\par
            f"Parallel mode: \{'ON' if parallel else 'OFF'\} | "\par
            f"max_workers=\{max_workers if parallel else 1\}"\par
        )\par
\par
        tasks = [\par
            \{\par
                "hold_bars": hb,\par
                "stop_distance_points": float(stop_pts),\par
                "min_avg_range": float(min_range),\par
                "momentum_lookback": int(mom_lb),\par
                "years_in_sample": years_in_sample,\par
                "min_trades": min_trades,\par
                "min_trades_per_year": min_trades_per_year,\par
            \}\par
            for hb, stop_pts, min_range, mom_lb in combinations\par
        ]\par
\par
        if parallel and total_runs > 1:\par
            with ProcessPoolExecutor(\par
                max_workers=max_workers,\par
                initializer=_init_refinement_worker,\par
                initargs=(\par
                    self.engine_class,\par
                    self.data,\par
                    self.strategy_factory,\par
                    self.config,\par
                ),\par
            ) as executor:\par
                for idx, result in enumerate(executor.map(_run_refinement_case, tasks), start=1):\par
                    if result["passes_trade_filter"]:\par
                        accepted_count += 1\par
                        self.results.append(RefinementResult(**result))\par
                    else:\par
                        rejected_count += 1\par
\par
                    print(\par
                        f"  Done \{idx\}/\{total_runs\} | "\par
                        f"hb=\{result['hold_bars']\}, "\par
                        f"stop=\{result['stop_distance_points']\}, "\par
                        f"range=\{result['min_avg_range']\}, "\par
                        f"mom=\{result['momentum_lookback']\} | "\par
                        f"PF=\{result['profit_factor']:.2f\} | "\par
                        f"\{'ACCEPT' if result['passes_trade_filter'] else 'REJECT'\}"\par
                    )\par
        else:\par
            _init_refinement_worker(\par
                self.engine_class,\par
                self.data,\par
                self.strategy_factory,\par
                self.config,\par
            )\par
\par
            for idx, task in enumerate(tasks, start=1):\par
                result = _run_refinement_case(task)\par
\par
                if result["passes_trade_filter"]:\par
                    accepted_count += 1\par
                    self.results.append(RefinementResult(**result))\par
                else:\par
                    rejected_count += 1\par
\par
                print(\par
                    f"  Done \{idx\}/\{total_runs\} | "\par
                    f"hb=\{result['hold_bars']\}, "\par
                    f"stop=\{result['stop_distance_points']\}, "\par
                    f"range=\{result['min_avg_range']\}, "\par
                    f"mom=\{result['momentum_lookback']\} | "\par
                    f"PF=\{result['profit_factor']:.2f\} | "\par
                    f"\{'ACCEPT' if result['passes_trade_filter'] else 'REJECT'\}"\par
                )\par
\par
        elapsed = time.perf_counter() - start_time\par
\par
        print(f"\\n\f3\u9989?\f5  Accepted refinement sets: \{accepted_count\}")\par
        print(f"\f3\u10060?\f5  Rejected refinement sets: \{rejected_count\}")\par
        print(f"\f3\u9201?\f5  Refinement runtime: \{elapsed:.2f\} seconds")\par
\par
        return self.results_dataframe()\par
\par
    def results_dataframe(self) -> pd.DataFrame:\par
        if not self.results:\par
            return pd.DataFrame()\par
\par
        df = pd.DataFrame([r.__dict__ for r in self.results])\par
        df = df.sort_values(\par
            by=["profit_factor", "average_trade", "net_pnl"],\par
            ascending=[False, False, False],\par
        ).reset_index(drop=True)\par
\par
        return df\par
\par
    def display_dataframe(self) -> pd.DataFrame:\par
        df = self.results_dataframe()\par
        if df.empty:\par
            return df\par
\par
        display_columns = [\par
            "hold_bars",\par
            "stop_distance_points",\par
            "min_avg_range",\par
            "momentum_lookback",\par
            "total_trades",\par
            "trades_per_year",\par
            "profit_factor",\par
            "average_trade",\par
            "net_pnl",\par
            "max_drawdown",\par
            "win_rate",\par
            "average_mae_points",\par
            "average_mfe_points",\par
        ]\par
\par
        available_columns = [c for c in display_columns if c in df.columns]\par
        out = df[available_columns].copy()\par
\par
        round_cols = [\par
            "stop_distance_points",\par
            "min_avg_range",\par
            "trades_per_year",\par
            "profit_factor",\par
            "average_trade",\par
            "net_pnl",\par
            "max_drawdown",\par
            "win_rate",\par
            "average_mae_points",\par
            "average_mfe_points",\par
        ]\par
        for col in round_cols:\par
            if col in out.columns:\par
                out[col] = out[col].round(2)\par
\par
        return out\par
\par
    def top_results(self, n: int = 10) -> pd.DataFrame:\par
        df = self.display_dataframe()\par
        if df.empty:\par
            return df\par
        return df.head(n)\par
\par
    def summary_report(self, top_n: int = 10) -> dict[str, Any]:\par
        df = self.results_dataframe()\par
        if df.empty:\par
            return \{\}\par
\par
        top_df = df.head(top_n)\par
\par
        best_pf = df.sort_values(by="profit_factor", ascending=False).iloc[0].to_dict()\par
        best_avg_trade = df.sort_values(by="average_trade", ascending=False).iloc[0].to_dict()\par
        best_net_pnl = df.sort_values(by="net_pnl", ascending=False).iloc[0].to_dict()\par
\par
        hold_counter = Counter(top_df["hold_bars"].tolist())\par
        stop_counter = Counter(top_df["stop_distance_points"].tolist())\par
        range_counter = Counter(top_df["min_avg_range"].tolist())\par
        mom_counter = Counter(top_df["momentum_lookback"].tolist())\par
\par
        return \{\par
            "best_pf": best_pf,\par
            "best_average_trade": best_avg_trade,\par
            "best_net_pnl": best_net_pnl,\par
            "top_n": top_n,\par
            "common_hold_bars": hold_counter.most_common(),\par
            "common_stop_distance_points": stop_counter.most_common(),\par
            "common_min_avg_range": range_counter.most_common(),\par
            "common_momentum_lookback": mom_counter.most_common(),\par
        \}\par
\par
    def print_summary_report(self, top_n: int = 10) -> None:\par
        report = self.summary_report(top_n=top_n)\par
        if not report:\par
            print("\\nNo refinement summary available.")\par
            return\par
\par
        print("\\n\f1\u-10178?\u-8736?\f5  Refinement Summary Report")\par
\par
        best_pf = report["best_pf"]\par
        print("\\nBest Profit Factor setting:")\par
        print(\par
            f"  hold_bars=\{best_pf['hold_bars']\}, "\par
            f"stop=\{best_pf['stop_distance_points']\}, "\par
            f"min_avg_range=\{best_pf['min_avg_range']\}, "\par
            f"momentum_lookback=\{best_pf['momentum_lookback']\} | "\par
            f"PF=\{best_pf['profit_factor']:.2f\}, "\par
            f"avg_trade=\{best_pf['average_trade']:.2f\}, "\par
            f"net_pnl=\{best_pf['net_pnl']:.2f\}"\par
        )\par
\par
        best_avg_trade = report["best_average_trade"]\par
        print("\\nBest Average Trade setting:")\par
        print(\par
            f"  hold_bars=\{best_avg_trade['hold_bars']\}, "\par
            f"stop=\{best_avg_trade['stop_distance_points']\}, "\par
            f"min_avg_range=\{best_avg_trade['min_avg_range']\}, "\par
            f"momentum_lookback=\{best_avg_trade['momentum_lookback']\} | "\par
            f"avg_trade=\{best_avg_trade['average_trade']:.2f\}, "\par
            f"PF=\{best_avg_trade['profit_factor']:.2f\}, "\par
            f"net_pnl=\{best_avg_trade['net_pnl']:.2f\}"\par
        )\par
\par
        best_net_pnl = report["best_net_pnl"]\par
        print("\\nBest Net PnL setting:")\par
        print(\par
            f"  hold_bars=\{best_net_pnl['hold_bars']\}, "\par
            f"stop=\{best_net_pnl['stop_distance_points']\}, "\par
            f"min_avg_range=\{best_net_pnl['min_avg_range']\}, "\par
            f"momentum_lookback=\{best_net_pnl['momentum_lookback']\} | "\par
            f"net_pnl=\{best_net_pnl['net_pnl']:.2f\}, "\par
            f"PF=\{best_net_pnl['profit_factor']:.2f\}, "\par
            f"avg_trade=\{best_net_pnl['average_trade']:.2f\}"\par
        )\par
\par
        print(f"\\nMost common values in top \{report['top_n']\} results:")\par
        print(f"  hold_bars: \{report['common_hold_bars']\}")\par
        print(f"  stop_distance_points: \{report['common_stop_distance_points']\}")\par
        print(f"  min_avg_range: \{report['common_min_avg_range']\}")\par
        print(f"  momentum_lookback: \{report['common_momentum_lookback']\}")\par
\par
    def save_results_csv(self, filepath: str | Path) -> Path:\par
        df = self.results_dataframe()\par
        if df.empty:\par
            raise ValueError("No refinement results to save.")\par
\par
        output_path = Path(filepath)\par
        output_path.parent.mkdir(parents=True, exist_ok=True)\par
        df.to_csv(output_path, index=False)\par
        return output_path\par
