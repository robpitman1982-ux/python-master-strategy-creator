from abc import ABC, abstractmethod\par
\par
import pandas as pd\par
\par
\par
class BaseFilter(ABC):\par
    """\par
    Base class for reusable strategy filters.\par
    """\par
\par
    name: str = "BaseFilter"\par
\par
    @abstractmethod\par
    def passes(self, data: pd.DataFrame, i: int) -> bool:\par
        raise NotImplementedError\par
\par
\par
# ============================================================\par
# Trend-family filters\par
# ============================================================\par
\par
class TrendDirectionFilter(BaseFilter):\par
    """\par
    Bull trend when fast SMA > slow SMA.\par
    """\par
\par
    name = "TrendDirectionFilter"\par
\par
    def __init__(self, fast_length: int = 50, slow_length: int = 200):\par
        self.fast_length = fast_length\par
        self.slow_length = slow_length\par
\par
    def passes(self, data: pd.DataFrame, i: int) -> bool:\par
        required_bars = max(self.fast_length, self.slow_length)\par
        if i < required_bars:\par
            return False\par
\par
        fast_col = f"sma_\{self.fast_length\}"\par
        slow_col = f"sma_\{self.slow_length\}"\par
\par
        if fast_col in data.columns and slow_col in data.columns:\par
            fast_sma = data.iloc[i][fast_col]\par
            slow_sma = data.iloc[i][slow_col]\par
        else:\par
            close_series = data["close"]\par
            fast_sma = close_series.iloc[i - self.fast_length + 1 : i + 1].mean()\par
            slow_sma = close_series.iloc[i - self.slow_length + 1 : i + 1].mean()\par
\par
        if pd.isna(fast_sma) or pd.isna(slow_sma):\par
            return False\par
\par
        return bool(fast_sma > slow_sma)\par
\par
\par
class PullbackFilter(BaseFilter):\par
    """\par
    Previous close is at or below the fast SMA.\par
    """\par
\par
    name = "PullbackFilter"\par
\par
    def __init__(self, fast_length: int = 50):\par
        self.fast_length = fast_length\par
\par
    def passes(self, data: pd.DataFrame, i: int) -> bool:\par
        if i < self.fast_length:\par
            return False\par
\par
        fast_col = f"sma_\{self.fast_length\}"\par
\par
        if fast_col in data.columns and "prev_close" in data.columns:\par
            prev_fast_sma = data.iloc[i - 1][fast_col]\par
            previous_close = data.iloc[i]["prev_close"]\par
        else:\par
            close_series = data["close"]\par
            prev_fast_sma = close_series.iloc[i - self.fast_length : i].mean()\par
            previous_close = close_series.iloc[i - 1]\par
\par
        if pd.isna(prev_fast_sma) or pd.isna(previous_close):\par
            return False\par
\par
        return bool(previous_close <= prev_fast_sma)\par
\par
