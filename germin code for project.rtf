from __future__ import annotations\par
\par
from pathlib import Path\par
import numpy as np\par
import pandas as pd\par
\par
def load_tradestation_csv(filepath: str | Path, debug: bool = True) -> pd.DataFrame:\par
    """\par
    Loads TradeStation CSV exports, handling custom date/time formats,\par
    cleaning string artifacts, and enforcing the 2008 backtest start date.\par
    """\par
    filepath = Path(filepath)\par
    if not filepath.exists():\par
        raise FileNotFoundError(f"CSV not found: \{filepath\}")\par
\par
    # Read as strings to control parsing\par
    df = pd.read_csv(filepath, dtype=str)\par
\par
    # Clean column names (strip spaces and quotes)\par
    df.columns = [c.strip().strip('"').strip("'") for c in df.columns]\par
\par
    required = \{"Date", "Time", "Open", "High", "Low", "Close"\}\par
    missing = required - set(df.columns)\par
    if missing:\par
        raise ValueError(f"Missing required columns: \{missing\}. Found: \{list(df.columns)\}")\par
\par
    if debug:\par
        print("\\n[LOADER DEBUG] Columns:", df.columns.tolist())\par
\par
    # ---- Datetime parsing ----\par
    dt_text = df["Date"].astype(str).str.strip() + " " + df["Time"].astype(str).str.strip()\par
\par
    dt_dayfirst = pd.to_datetime(dt_text, errors="coerce", dayfirst=True)\par
    dt_monthfirst = pd.to_datetime(dt_text, errors="coerce", dayfirst=False)\par
\par
    nat_dayfirst = int(dt_dayfirst.isna().sum())\par
    nat_monthfirst = int(dt_monthfirst.isna().sum())\par
\par
    # Choose the parse with fewer NaT (Not a Time)\par
    dt = dt_dayfirst if nat_dayfirst <= nat_monthfirst else dt_monthfirst\par
\par
    # ---- Numeric helper ----\par
    def num(series: pd.Series) -> pd.Series:\par
        # strip quotes/spaces; remove commas\par
        x = (\par
            series.astype(str)\par
            .str.replace('"', "", regex=False)\par
            .str.replace(",", "", regex=False)\par
            .str.strip()\par
        )\par
        return pd.to_numeric(x, errors="coerce")\par
\par
    open_ = num(df["Open"])\par
    high_ = num(df["High"])\par
    low_ = num(df["Low"])\par
    close_ = num(df["Close"])\par
\par
    if "Volume" in df.columns:\par
        vol = num(df["Volume"]).fillna(0)\par
    elif "Up" in df.columns and "Down" in df.columns:\par
        vol = (num(df["Up"]).fillna(0) + num(df["Down"]).fillna(0))\par
    else:\par
        vol = pd.Series(np.zeros(len(df)), index=df.index)\par
\par
    # ---- Construct DataFrame (Using .values to fix the index alignment bug) ----\par
    out = pd.DataFrame(\par
        \{\par
            "open": open_.values, \par
            "high": high_.values, \par
            "low": low_.values, \par
            "close": close_.values, \par
            "volume": vol.values\par
        \},\par
        index=dt,\par
    )\par
    out.index.name = "datetime"\par
\par
    # ---- Clean and Filter ----\par
    out = out[~out.index.isna()]  # drop NaT datetimes\par
    out = out.dropna(subset=["open", "high", "low", "close"])  # drop bad OHLC rows\par
    out = out.sort_index()\par
    out = out[~out.index.duplicated(keep="last")]\par
\par
    # Master Prompt Enforcement: Start Date 01 January 2008\par
    out = out.loc["2008-01-01":]\par
\par
    if debug:\par
        print(f"[LOADER DEBUG] Final rows after cleaning and filtering: \{len(out):,\}")\par
\par
    return out\par
\par
