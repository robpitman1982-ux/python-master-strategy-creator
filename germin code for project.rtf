\par
class BaseStrategyType(ABC):\par
    """\par
    Base interface for all strategy families.\par
    Every strategy type must implement the methods the master engine expects.\par
    """\par
\par
    name: str = "base"\par
\par
    min_filters_per_combo: int = 3\par
    max_filters_per_combo: int = 5\par
\par
    default_hold_bars: int = 3\par
    default_stop_distance_points: float = 10.0\par
\par
    @abstractmethod\par
    def get_filter_classes(self) -> list[type]:\par
        raise NotImplementedError\par
\par
    @abstractmethod\par
    def build_filter_objects_from_classes(self, combo_classes: list[type]) -> list:\par
        raise NotImplementedError\par
\par
    @abstractmethod\par
    def build_combinable_strategy(\par
        self,\par
        filters: list,\par
        hold_bars: int,\par
        stop_distance_points: float,\par
    ):\par
        raise NotImplementedError\par
\par
    @abstractmethod\par
    def build_default_sanity_filters(self) -> list:\par
        raise NotImplementedError\par
\par
    @abstractmethod\par
    def build_candidate_specific_strategy(\par
        self,\par
        promoted_combo_classes: list[type],\par
        hold_bars: int,\par
        stop_distance_points: float,\par
        min_avg_range: float,\par
        momentum_lookback: int,\par
    ):\par
        raise NotImplementedError\par
\par
    @abstractmethod\par
    def get_active_refinement_grid_for_combo(\par
        self,\par
        promoted_combo_classes: list[type],\par
    ) -> dict[str, list]:\par
        raise NotImplementedError\par
\par
    @abstractmethod\par
    def get_trade_filter_thresholds(self) -> dict[str, float]:\par
        raise NotImplementedError\par
\par
    @abstractmethod\par
    def get_promotion_thresholds(self) -> dict[str, float | bool]:\par
        raise NotImplementedError\par
\par
    @abstractmethod\par
    def get_required_sma_lengths(self) -> list[int]:\par
        raise NotImplementedError\par
\par
    @abstractmethod\par
    def get_required_avg_range_lookbacks(self) -> list[int]:\par
        raise NotImplementedError\par
\par
    @abstractmethod\par
    def get_required_momentum_lookbacks(self) -> list[int]:\par
        raise NotImplementedError\par
