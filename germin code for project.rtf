class BreakoutStrategyType(BaseStrategyType):\par
    name = "breakout"\par
    strategy_type_name = "breakout"\par
\par
    min_filters_per_combo = 3\par
    max_filters_per_combo = 7\par
\par
    default_hold_bars = 10\par
    default_stop_distance_points = 14.0\par
\par
    # -------------------------------------------------------------------------\par
    # Required feature lookbacks\par
    # -------------------------------------------------------------------------\par
    def get_required_sma_lengths(self) -> list[int]:\par
        return [50, 200]\par
\par
    def get_required_avg_range_lookbacks(self) -> list[int]:\par
        return [20]\par
\par
    def get_required_momentum_lookbacks(self) -> list[int]:\par
        return []\par
\par
    # -------------------------------------------------------------------------\par
    # Default / sanity setup\par
    # -------------------------------------------------------------------------\par
    def build_default_sanity_filters(self) -> list[Any]:\par
        return [\par
            CompressionFilter(lookback=20, compression_threshold=0.85),\par
            PriorRangePositionFilter(lookback=20, min_position_in_range=0.60),\par
            RangeBreakoutFilter(lookback=20),\par
            MinimumBreakDistanceFilter(min_break_distance_points=1.0),\par
            ExpansionBarFilter(lookback=20, min_expansion_multiple=1.20),\par
            BreakoutCloseStrengthFilter(min_close_strength=0.60),\par
            BreakoutTrendFilter(sma_column="sma_50"),\par
        ]\par
\par
    def build_default_strategy(self) -> _InlineBreakoutStrategy:\par
        return _InlineBreakoutStrategy(\par
            filters=self.build_default_sanity_filters(),\par
            hold_bars=self.default_hold_bars,\par
            stop_distance_points=self.default_stop_distance_points,\par
            name="FilterBasedBreakoutStrategy",\par
        )\par
\par
    def build_sanity_check_strategy(self) -> _InlineBreakoutStrategy:\par
        return self.build_default_strategy()\par
\par
    # -------------------------------------------------------------------------\par
    # Filter library\par
    # -------------------------------------------------------------------------\par
    def get_filter_classes(self) -> list[type]:\par
        return [\par
            CompressionFilter,\par
            PriorRangePositionFilter,\par
            RangeBreakoutFilter,\par
            MinimumBreakDistanceFilter,\par
            ExpansionBarFilter,\par
            BreakoutCloseStrengthFilter,\par
            BreakoutTrendFilter,\par
        ]\par
\par
    def build_filter_objects_from_classes(\par
        self,\par
        combo_classes: list[type],\par
        *,\par
        min_avg_range: float = 8.0,\par
        momentum_lookback: int = 10,  # kept for interface compatibility\par
    ) -> list[Any]:\par
        filters: list[Any] = []\par
\par
        for cls in combo_classes:\par
            if cls is CompressionFilter:\par
                filters.append(\par
                    CompressionFilter(\par
                        lookback=20,\par
                        compression_threshold=0.85,\par
                    )\par
                )\par
            elif cls is PriorRangePositionFilter:\par
                filters.append(\par
                    PriorRangePositionFilter(\par
                        lookback=20,\par
                        min_position_in_range=0.60,\par
                    )\par
                )\par
            elif cls is RangeBreakoutFilter:\par
                filters.append(RangeBreakoutFilter(lookback=20))\par
            elif cls is MinimumBreakDistanceFilter:\par
                filters.append(\par
                    MinimumBreakDistanceFilter(\par
                        min_break_distance_points=1.0,\par
                    )\par
                )\par
            elif cls is ExpansionBarFilter:\par
                filters.append(\par
                    ExpansionBarFilter(\par
                        lookback=20,\par
                        min_expansion_multiple=1.20,\par
                    )\par
                )\par
            elif cls is BreakoutCloseStrengthFilter:\par
                filters.append(\par
                    BreakoutCloseStrengthFilter(\par
                        min_close_strength=0.60,\par
                    )\par
                )\par
            elif cls is BreakoutTrendFilter:\par
                filters.append(BreakoutTrendFilter(sma_column="sma_50"))\par
            else:\par
                raise ValueError(f"Unsupported breakout filter class: \{cls\}")\par
\par
        return filters\par
\par
    # -------------------------------------------------------------------------\par
    # Strategy builders\par
    # -------------------------------------------------------------------------\par
    def build_combinable_strategy(\par
        self,\par
        filters: list[Any],\par
        hold_bars: int,\par
        stop_distance_points: float,\par
    ) -> _InlineBreakoutStrategy:\par
        return _InlineBreakoutStrategy(\par
            filters=filters,\par
            hold_bars=hold_bars,\par
            stop_distance_points=stop_distance_points,\par
            name="CombinableBreakoutStrategy",\par
        )\par
\par
    def build_candidate_specific_strategy(\par
        self,\par
        promoted_combo_classes: list[type],\par
        hold_bars: int,\par
        stop_distance_points: float,\par
        min_avg_range: float,\par
        momentum_lookback: int,\par
    ) -> _InlineBreakoutStrategy:\par
        filters = self.build_filter_objects_from_classes(\par
            promoted_combo_classes,\par
            min_avg_range=min_avg_range,\par
            momentum_lookback=momentum_lookback,\par
        )\par
\par
        return _InlineBreakoutStrategy(\par
            filters=filters,\par
            hold_bars=hold_bars,\par
            stop_distance_points=stop_distance_points,\par
            name=(\par
                f"RefinedBreakoutStrategy_"\par
                f"HB\{hold_bars\}_STOP\{stop_distance_points\}_"\par
                f"RANGE\{min_avg_range\}_MOM\{momentum_lookback\}"\par
            ),\par
        )\par
\par
    # -------------------------------------------------------------------------\par
    # Promotion / trade thresholds\par
    # -------------------------------------------------------------------------\par
    def get_promotion_gate_config(self) -> dict[str, Any]:\par
        return \{\par
            "min_profit_factor": 1.00,\par
            "min_average_trade": 0.00,\par
            "require_positive_net_pnl": False,\par
            "min_trades": 150,\par
            "min_trades_per_year": 8.0,\par
        \}\par
\par
    def get_promotion_thresholds(self) -> dict[str, Any]:\par
        return self.get_promotion_gate_config()\par
\par
    def get_trade_filter_thresholds(self) -> dict[str, Any]:\par
        return \{\par
            "min_trades": 150,\par
            "min_trades_per_year": 8.0,\par
        \}\par
\par
    # -------------------------------------------------------------------------\par
    # Refinement grid\par
    # -------------------------------------------------------------------------\par
    def get_active_refinement_grid_for_combo(\par
        self,\par
        promoted_combo_classes: list[type],\par
    ) -> dict[str, list[Any]]:\par
        return \{\par
            "hold_bars": [4, 6, 8, 10],\par
            "stop_distance_points": [10.0, 12.0, 14.0, 16.0],\par
            "min_avg_range": [6.0, 7.0, 8.0, 9.0],\par
            "momentum_lookback": [10, 15, 20, 25],\par
        \}\par
\par
    def get_refinement_grid_for_candidate(\par
        self,\par
        candidate_row: dict[str, Any],\par
    ) -> dict[str, list[Any]]:\par
        promoted_combo_classes = candidate_row["filter_classes"]\par
        return self.get_active_refinement_grid_for_combo(promoted_combo_classes)\par
\par
    # -------------------------------------------------------------------------\par
    # Sweep / refinement runners\par
    # -------------------------------------------------------------------------\par
    def run_filter_combination_sweep(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        print("\\n\f1\u-10178?\u-8726?\f0  Running breakout filter combination sweep...")\par
\par
        filter_classes = self.get_filter_classes()\par
\par
        combos: list[tuple[type, ...]] = []\par
        for r in range(self.min_filters_per_combo, len(filter_classes) + 1):\par
            combos.extend(itertools.combinations(filter_classes, r))\par
\par
        total = len(combos)\par
        print(f"Total filter combinations: \{total\}")\par
        print(f"Parallel mode: ON | max_workers=\{max_workers\}")\par
\par
        results: list[dict[str, Any]] = []\par
\par
        def evaluate_combo(combo_idx: int, combo: tuple[type, ...]) -> dict[str, Any]:\par
            combo_classes = list(combo)\par
            combo_name = "ComboBreakout_" + "_".join(\par
                cls.__name__.replace("Filter", "") for cls in combo_classes\par
            )\par
            print(f"  Combo \{combo_idx\}/\{total\} | \{combo_name\}")\par
\par
            filters = self.build_filter_objects_from_classes(combo_classes)\par
            strategy = self.build_combinable_strategy(\par
                filters=filters,\par
                hold_bars=self.default_hold_bars,\par
                stop_distance_points=self.default_stop_distance_points,\par
            )\par
\par
            engine = MasterStrategyEngine(data=data, config=cfg)\par
            engine.run(strategy=strategy)\par
            stats = engine.results()\par
\par
            total_trades = _parse_int(stats.get("Total Trades", 0))\par
            profit_factor = _parse_float(stats.get("Profit Factor", 0.0))\par
            avg_trade = _parse_money(stats.get("Average Trade", 0.0))\par
            net_pnl = _parse_money(stats.get("Net PnL", 0.0))\par
\par
            years = max((data.index.max() - data.index.min()).days / 365.25, 1e-9)\par
            trades_per_year = total_trades / years if years > 0 else 0.0\par
\par
            return \{\par
                "strategy_name": combo_name,\par
                "filter_classes": combo_classes,\par
                "filters": ",".join(cls.__name__ for cls in combo_classes),\par
                "profit_factor": profit_factor,\par
                "average_trade": avg_trade,\par
                "net_pnl": net_pnl,\par
                "total_trades": total_trades,\par
                "trades_per_year": trades_per_year,\par
                "avg_mfe_pts": _parse_float(stats.get("Average MFE (pts)", 0.0)),\par
                "avg_mae_pts": _parse_float(stats.get("Average MAE (pts)", 0.0)),\par
            \}\par
\par
        with ThreadPoolExecutor(max_workers=max_workers) as executor:\par
            futures = \{\par
                executor.submit(evaluate_combo, idx + 1, combo): combo\par
                for idx, combo in enumerate(combos)\par
            \}\par
            for future in as_completed(futures):\par
                results.append(future.result())\par
\par
        if not results:\par
            return pd.DataFrame()\par
\par
        df = pd.DataFrame(results)\par
        df = df.sort_values(\par
            by=["profit_factor", "average_trade", "net_pnl"],\par
            ascending=[False, False, False],\par
        ).reset_index(drop=True)\par
\par
        return df\par
\par
    def run_family_filter_combination_sweep(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        return self.run_filter_combination_sweep(\par
            data=data,\par
            cfg=cfg,\par
            max_workers=max_workers,\par
        )\par
\par
    def run_top_combo_refinement(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        candidate_row: dict[str, Any],\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        print("\\n\f2\u-10180?\u-8273?\f0  Running top-combo parameter refinement...")\par
\par
        grid = self.get_refinement_grid_for_candidate(candidate_row)\par
\par
        hold_bars_values = grid["hold_bars"]\par
        stop_values = grid["stop_distance_points"]\par
        range_values = grid["min_avg_range"]\par
        mom_values = grid["momentum_lookback"]\par
\par
        combos = list(\par
            itertools.product(\par
                hold_bars_values,\par
                stop_values,\par
                range_values,\par
                mom_values,\par
            )\par
        )\par
\par
        total = len(combos)\par
        years = max((data.index.max() - data.index.min()).days / 365.25, 1e-9)\par
        trade_filters = self.get_trade_filter_thresholds()\par
\par
        print(f"Total combinations: \{total\}")\par
        print(f"Years in sample: \{years:.2f\}")\par
        print(\par
            f"Trade filters: min_trades=\{trade_filters['min_trades']\}, "\par
            f"min_trades_per_year=\{trade_filters['min_trades_per_year']:.2f\}"\par
        )\par
        print(f"Parallel mode: ON | max_workers=\{max_workers\}")\par
\par
        accepted_rows: list[dict[str, Any]] = []\par
        rejected_rows = 0\par
\par
        promoted_combo_classes = candidate_row["filter_classes"]\par
\par
        def evaluate_refinement(combo_idx: int, combo: tuple[Any, ...]) -> tuple[dict[str, Any], bool]:\par
            hold_bars, stop_distance_points, min_avg_range, momentum_lookback = combo\par
\par
            strategy = self.build_candidate_specific_strategy(\par
                promoted_combo_classes=promoted_combo_classes,\par
                hold_bars=hold_bars,\par
                stop_distance_points=stop_distance_points,\par
                min_avg_range=min_avg_range,\par
                momentum_lookback=momentum_lookback,\par
            )\par
\par
            engine = MasterStrategyEngine(data=data, config=cfg)\par
            engine.run(strategy=strategy)\par
            stats = engine.results()\par
\par
            total_trades = _parse_int(stats.get("Total Trades", 0))\par
            trades_per_year = total_trades / years if years > 0 else 0.0\par
            profit_factor = _parse_float(stats.get("Profit Factor", 0.0))\par
            average_trade = _parse_money(stats.get("Average Trade", 0.0))\par
            net_pnl = _parse_money(stats.get("Net PnL", 0.0))\par
\par
            passes_trade_filter = (\par
                total_trades >= trade_filters["min_trades"]\par
                and trades_per_year >= trade_filters["min_trades_per_year"]\par
            )\par
\par
            row = \{\par
                "strategy_name": strategy.name,\par
                "hold_bars": hold_bars,\par
                "stop_distance_points": stop_distance_points,\par
                "min_avg_range": min_avg_range,\par
                "momentum_lookback": momentum_lookback,\par
                "profit_factor": profit_factor,\par
                "average_trade": average_trade,\par
                "net_pnl": net_pnl,\par
                "total_trades": total_trades,\par
                "trades_per_year": trades_per_year,\par
                "average_mfe_points": _parse_float(stats.get("Average MFE (pts)", 0.0)),\par
                "average_mae_points": _parse_float(stats.get("Average MAE (pts)", 0.0)),\par
            \}\par
\par
            status = "ACCEPT" if passes_trade_filter else "REJECT"\par
            print(\par
                f"  Done \{combo_idx\}/\{total\} | "\par
                f"hb=\{hold_bars\}, stop=\{stop_distance_points\}, "\par
                f"range=\{min_avg_range\}, mom=\{momentum_lookback\} | "\par
                f"PF=\{profit_factor:.2f\} | \{status\}"\par
            )\par
\par
            return row, passes_trade_filter\par
\par
        with ThreadPoolExecutor(max_workers=max_workers) as executor:\par
            futures = \{\par
                executor.submit(evaluate_refinement, idx + 1, combo): combo\par
                for idx, combo in enumerate(combos)\par
            \}\par
            for future in as_completed(futures):\par
                row, accepted = future.result()\par
                if accepted:\par
                    accepted_rows.append(row)\par
                else:\par
                    rejected_rows += 1\par
\par
        print(f"\\n\f3\u9989?\f0  Accepted refinement sets: \{len(accepted_rows)\}")\par
        print(f"\f3\u10060?\f0  Rejected refinement sets: \{rejected_rows\}")\par
\par
        if not accepted_rows:\par
            return pd.DataFrame()\par
\par
        df = pd.DataFrame(accepted_rows)\par
        df = df.sort_values(\par
            by=["profit_factor", "average_trade", "net_pnl"],\par
            ascending=[False, False, False],\par
        ).reset_index(drop=True)\par
\par
        return df\par
\par
    def run_refinement_for_candidate(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        candidate_row: dict[str, Any],\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        return self.run_top_combo_refinement(\par
            data=data,\par
            cfg=cfg,\par
            candidate_row=candidate_row,\par
            max_workers=max_workers,\par
        )\par
