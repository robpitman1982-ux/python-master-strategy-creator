# HELPERS\par
# =============================================================================\par
def _parse_money(value: Any) -> float:\par
    if isinstance(value, (int, float)):\par
        return float(value)\par
    text = str(value).replace("$", "").replace(",", "").strip()\par
    if not text:\par
        return 0.0\par
    return float(text)\par
\par
\par
def _parse_float(value: Any) -> float:\par
    if isinstance(value, (int, float)):\par
        return float(value)\par
    text = str(value).replace("%", "").strip()\par
    if not text:\par
        return 0.0\par
    return float(text)\par
\par
\par
def _parse_int(value: Any) -> int:\par
    if isinstance(value, int):\par
        return value\par
    if isinstance(value, float):\par
        return int(value)\par
    text = str(value).replace(",", "").strip()\par
    if not text:\par
        return 0\par
    return int(float(text))\par
