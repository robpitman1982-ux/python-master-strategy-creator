class TestStrategy(BaseStrategy):\par
    name = "TestStrategy"\par
    direction = "LONG_ONLY"\par
    hold_bars = 3\par
    stop_distance_points = 10.0\par
\par
    def generate_signal(self, data: pd.DataFrame, i: int) -> int:\par
        if i < 1:\par
            return 0\par
\par
        current_close = data["close"].iloc[i]\par
        previous_close = data["close"].iloc[i - 1]\par
\par
        if current_close > previous_close:\par
            return 1\par
\par
        return 0\par
\par
