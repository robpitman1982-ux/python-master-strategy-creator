class _InlineBreakoutStrategy:\par
    """\par
    Self-contained breakout strategy so we do not depend on missing breakout\par
    classes inside modules.strategies.\par
    """\par
\par
    direction = "LONG_ONLY"\par
\par
    def __init__(\par
        self,\par
        filters: list[Any],\par
        hold_bars: int = 10,\par
        stop_distance_points: float = 14.0,\par
        name: str = "FilterBasedBreakoutStrategy",\par
    ) -> None:\par
        self.filters = filters\par
        self.hold_bars = hold_bars\par
        self.stop_distance_points = stop_distance_points\par
        self.name = name\par
\par
    def generate_signal(self, data: pd.DataFrame, i: int) -> int:\par
        for filter_obj in self.filters:\par
            if not filter_obj.passes(data, i):\par
                return 0\par
        return 1\par
