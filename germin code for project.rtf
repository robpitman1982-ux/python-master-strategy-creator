            hold_bars=filters.get("hold_bars", self.default_hold_bars),\par
            stop_distance_points=filters.get(\par
                "stop_distance_points",\par
                self.default_stop_distance_points,\par
            ),\par
        )\par
\par
    def build_candidate_specific_strategy(\par
        self,\par
        promoted_combo_classes: list[type],\par
        hold_bars: int,\par
        stop_distance_points: float,\par
        min_avg_range: float,\par
        momentum_lookback: int,\par
    ):\par
        return RefinedFiveFilterTrendStrategy(\par
            hold_bars=hold_bars,\par
            stop_distance_points=stop_distance_points,\par
            fast_length=50,\par
            slow_length=200,\par
            volatility_lookback=20,\par
            min_avg_range=min_avg_range,\par
            momentum_lookback=momentum_lookback,\par
        )\par
\par
    def build_candidate_specific_refinement_factory(self, candidate_row: dict[str, Any]):\par
        return RefinedFiveFilterTrendStrategy\par
\par
    # -------------------------------------------------------------------------\par
    # Thresholds and gates\par
    # -------------------------------------------------------------------------\par
    def get_trade_filter_thresholds(self) -> dict[str, float]:\par
        return \{\par
            "min_trades": 150,\par
            "min_trades_per_year": 8.0,\par
        \}\par
\par
    def get_trade_filter_config(self) -> dict[str, float]:\par
        return self.get_trade_filter_thresholds()\par
\par
    def get_promotion_thresholds(self) -> dict[str, float | bool]:\par
        return \{\par
            "min_profit_factor": 1.00,\par
            "min_average_trade": 0.0,\par
            "require_positive_net_pnl": False,\par
        \}\par
\par
    def get_promotion_gate_config(self) -> dict[str, float | bool]:\par
        return self.get_promotion_thresholds()\par
\par
    # -------------------------------------------------------------------------\par
    # Refinement grids\par
    # -------------------------------------------------------------------------\par
    def get_active_refinement_grid_for_combo(\par
        self,\par
        promoted_combo_classes: list[type],\par
    ) -> dict[str, list]:\par
        return \{\par
            "hold_bars": [8, 9, 10, 11, 12],\par
            "stop_distance_points": [9.0, 10.0, 11.0, 12.0],\par
            "min_avg_range": [8.0, 8.5, 9.0, 9.5],\par
            "momentum_lookback": [11, 12, 13, 14],\par
        \}\par
\par
    def get_refinement_grid_for_candidate(self, candidate_row: dict[str, Any]) -> dict[str, list]:\par
        combo_classes = self.get_filter_classes()\par
        return self.get_active_refinement_grid_for_combo(combo_classes)\par
\par
    # -------------------------------------------------------------------------\par
    # Sweep\par
    # -------------------------------------------------------------------------\par
    def run_filter_combination_sweep(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        return self.run_family_filter_combination_sweep(\par
            data=data,\par
            cfg=cfg,\par
            max_workers=max_workers,\par
        )\par
\par
    def run_family_filter_combination_sweep(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        filter_classes = self.get_filter_classes()\par
\par
        combinations = generate_filter_combinations(\par
            filter_classes=filter_classes,\par
            min_filters=self.min_filters_per_combo,\par
            max_filters=self.max_filters_per_combo,\par
        )\par
\par
        print("\\n\f1\u-10178?\u-8726?\f0  Running trend filter combination sweep...")\par
        print(f"Total filter combinations: \{len(combinations)\}")\par
        print(f"Parallel mode: ON | max_workers=\{max_workers\}")\par
\par
        tasks = [(data, cfg, combo_classes) for combo_classes in combinations]\par
        results: list[dict[str, Any]] = []\par
\par
        with ProcessPoolExecutor(max_workers=max_workers) as executor:\par
            for idx, result in enumerate(executor.map(_run_trend_combo_case, tasks), start=1):\par
                print(f"  Combo \{idx\}/\{len(combinations)\} | \{result['strategy_name']\}")\par
                results.append(result)\par
\par
        results_df = pd.DataFrame(results)\par
\par
        if not results_df.empty:\par
            results_df = results_df.sort_values(\par
                by=["passes_trade_filter", "profit_factor", "average_trade", "net_pnl"],\par
                ascending=[False, False, False, False],\par
            ).reset_index(drop=True)\par
\par
        return results_df\par
\par
    # -------------------------------------------------------------------------\par
    # Refinement\par
    # -------------------------------------------------------------------------\par
    def run_refinement_for_candidate(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        candidate_row: dict[str, Any],\par
        output_dir: str | Path = "Outputs",\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        refiner = StrategyParameterRefiner(\par
            engine_class=MasterStrategyEngine,\par
            data=data,\par
            strategy_factory=RefinedFiveFilterTrendStrategy,\par
            config=cfg,\par
        )\par
\par
        grid = self.get_refinement_grid_for_candidate(candidate_row)\par
        trade_filters = self.get_trade_filter_thresholds()\par
\par
        refinement_df = refiner.run_refinement(\par
            hold_bars=grid["hold_bars"],\par
            stop_distance_points=grid["stop_distance_points"],\par
            min_avg_range=grid["min_avg_range"],\par
            momentum_lookback=grid["momentum_lookback"],\par
            min_trades=trade_filters["min_trades"],\par
            min_trades_per_year=trade_filters["min_trades_per_year"],\par
            parallel=True,\par
            max_workers=max_workers,\par
        )\par
\par
        if not refinement_df.empty:\par
            print("\\n\f2\u-10180?\u-8273?\f0  Top trend Refinement Results:")\par
            print(refiner.top_results(10))\par
            refiner.print_summary_report(top_n=10)\par
\par
            plateau = PlateauAnalyzer(refinement_df)\par
            plateau.print_report(top_n=10)\par
\par
            output_path = Path(output_dir) / "trend_top_combo_refinement_results_narrow.csv"\par
            saved_path = refiner.save_results_csv(output_path)\par
            print(f"\\n\f2\u-10179?\u-9026?\f0  Narrow top-combo refinement saved to: \{saved_path\}")\par
        else:\par
            print("\\nNo refinement results met the trade filters.")\par
\par
        return refinement_df\par
\par
    def run_top_combo_refinement(\par
        self,\par
        data: pd.DataFrame,\par
        cfg: EngineConfig,\par
        candidate_row: dict[str, Any],\par
        output_dir: str | Path = "Outputs",\par
        max_workers: int = 10,\par
    ) -> pd.DataFrame:\par
        return self.run_refinement_for_candidate(\par
            data=data,\par
            cfg=cfg,\par
            candidate_row=candidate_row,\par
            output_dir=output_dir,\par
            max_workers=max_workers,\par
        )\par
