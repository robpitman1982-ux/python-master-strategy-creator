\par
        heatmap = self.df.pivot_table(\par
            values=metric,\par
            index=index_param,\par
            columns=column_param,\par
            aggfunc="mean"\par
        )\par
\par
        return heatmap.round(3)\par
\par
    def print_heatmap(\par
