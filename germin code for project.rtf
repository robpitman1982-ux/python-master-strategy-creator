            return False\par
\par
        avg_range_col = f"avg_range_\{self.lookback\}"\par
\par
        if avg_range_col in data.columns:\par
            avg_range = data.iloc[i][avg_range_col]\par
        else:\par
            window = data.iloc[i - self.lookback + 1 : i + 1]\par
