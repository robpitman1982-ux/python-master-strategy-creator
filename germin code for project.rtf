from __future__ import annotations\par
\par
from dataclasses import dataclass\par
from itertools import product\par
from pathlib import Path\par
from typing import Any, Type\par
\par
import pandas as pd\par
\par
from modules.engine import EngineConfig\par
\par
\par
@dataclass\par
class OptimizationResult:\par
    strategy_name: str\par
    hold_bars: int\par
    stop_distance_points: float\par
    total_trades: int\par
    years_in_sample: float\par
    trades_per_year: float\par
    passes_trade_filter: bool\par
    net_pnl: float\par
    gross_profit: float\par
    gross_loss: float\par
    average_trade: float\par
    profit_factor: float\par
    max_drawdown: float\par
    win_rate: float\par
    average_mae_points: float\par
    average_mfe_points: float\par
\par
\par
class StrategyOptimizer:\par
    """\par
    Runs simple grid-search optimization over strategy parameters.\par
    Applies trade-frequency filters to reject statistically weak parameter sets.\par
    """\par
\par
    def __init__(\par
        self,\par
        engine_class: Type,\par
        data: pd.DataFrame,\par
        strategy_class: Type,\par
        config: EngineConfig | None = None,\par
    ):\par
        self.engine_class = engine_class\par
        self.data = data\par
        self.strategy_class = strategy_class\par
        self.config = config or EngineConfig()\par
        self.results: list[OptimizationResult] = []\par
\par
    @staticmethod\par
    def _parse_money(value: Any) -> float:\par
        """\par
        Converts strings like '$-200,201.50' into float.\par
        """\par
        if isinstance(value, (int, float)):\par
            return float(value)\par
\par
        text = str(value).replace("$", "").replace(",", "").strip()\par
        return float(text)\par
\par
    @staticmethod\par
    def _parse_percent(value: Any) -> float:\par
        """\par
        Converts strings like '34.84%' into float.\par
        """\par
        if isinstance(value, (int, float)):\par
            return float(value)\par
\par
        text = str(value).replace("%", "").strip()\par
        return float(text)\par
\par
    def _calculate_years_in_sample(self) -> float:\par
        """\par
        Estimate years covered by the dataset using the datetime index.\par
        """\par
        if self.data.empty:\par
            return 0.0\par
\par
        start = self.data.index.min()\par
        end = self.data.index.max()\par
\par
        total_days = (end - start).days\par
        if total_days <= 0:\par
            return 0.0\par
\par
        return total_days / 365.25\par
\par
    def run_grid_search(\par
        self,\par
        hold_bars: list[int],\par
        stop_distance_points: list[float],\par
        min_trades: int = 0,\par
        min_trades_per_year: float = 0.0,\par
    ) -> pd.DataFrame:\par
        """\par
        Runs all combinations of hold_bars and stop_distance_points.\par
        Returns a dataframe of accepted optimization results only.\par
        """\par
        self.results = []\par
\par
        combinations = list(product(hold_bars, stop_distance_points))\par
        total_runs = len(combinations)\par
        years_in_sample = self._calculate_years_in_sample()\par
\par
        print("\\n\f2\u-10179?\u-8947?\f0  Running optimization grid search...")\par
        print(f"Total combinations: \{total_runs\}")\par
        print(f"Years in sample: \{years_in_sample:.2f\}")\par
        print(f"Trade filters: min_trades=\{min_trades\}, min_trades_per_year=\{min_trades_per_year:.2f\}")\par
\par
        accepted_count = 0\par
        rejected_count = 0\par
\par
        for run_number, (hb, stop_pts) in enumerate(combinations, start=1):\par
            print(\par
                f"  Run \{run_number\}/\{total_runs\} | "\par
                f"hold_bars=\{hb\}, stop_distance_points=\{stop_pts\}"\par
            )\par
\par
            strategy = self.strategy_class()\par
            strategy.hold_bars = hb\par
            strategy.stop_distance_points = float(stop_pts)\par
\par
            engine = self.engine_class(data=self.data, config=self.config)\par
            engine.run(strategy=strategy)\par
\par
            summary = engine.results()\par
            total_trades = int(summary["Total Trades"])\par
\par
            trades_per_year = (\par
                total_trades / years_in_sample if years_in_sample > 0 else 0.0\par
            )\par
\par
            passes_trade_filter = (\par
                total_trades >= min_trades\par
                and trades_per_year >= min_trades_per_year\par
            )\par
\par
            if not passes_trade_filter:\par
                rejected_count += 1\par
                print(\par
                    f"    \f4\u8627?\f0  Rejected by trade filter "\par
                    f"(trades=\{total_trades\}, trades/year=\{trades_per_year:.2f\})"\par
                )\par
                continue\par
\par
            result = OptimizationResult(\par
                strategy_name=str(summary["Strategy"]),\par
                hold_bars=hb,\par
                stop_distance_points=float(stop_pts),\par
                total_trades=total_trades,\par
                years_in_sample=years_in_sample,\par
                trades_per_year=trades_per_year,\par
                passes_trade_filter=passes_trade_filter,\par
                net_pnl=self._parse_money(summary["Net PnL"]),\par
                gross_profit=self._parse_money(summary["Gross Profit"]),\par
                gross_loss=self._parse_money(summary["Gross Loss"]),\par
                average_trade=self._parse_money(summary["Average Trade"]),\par
                profit_factor=float(summary["Profit Factor"]),\par
                max_drawdown=self._parse_money(summary["Max Drawdown"]),\par
                win_rate=self._parse_percent(summary["Win Rate"]),\par
                average_mae_points=float(summary["Average MAE (pts)"]),\par
                average_mfe_points=float(summary["Average MFE (pts)"]),\par
            )\par
            self.results.append(result)\par
            accepted_count += 1\par
\par
        print(f"\\n\f3\u9989?\f0  Accepted parameter sets: \{accepted_count\}")\par
        print(f"\f3\u10060?\f0  Rejected parameter sets: \{rejected_count\}")\par
\par
        return self.results_dataframe()\par
\par
    def results_dataframe(self) -> pd.DataFrame:\par
        if not self.results:\par
            return pd.DataFrame()\par
\par
        df = pd.DataFrame([r.__dict__ for r in self.results])\par
\par
        sort_columns = ["profit_factor", "average_trade", "net_pnl"]\par
        existing_sort_columns = [col for col in sort_columns if col in df.columns]\par
\par
        if existing_sort_columns:\par
            df = df.sort_values(\par
                by=existing_sort_columns,\par
                ascending=[False] * len(existing_sort_columns),\par
            ).reset_index(drop=True)\par
\par
        return df\par
\par
    def display_dataframe(self) -> pd.DataFrame:\par
        """\par
        Returns a cleaner dataframe for terminal display.\par
        """\par
        df = self.results_dataframe()\par
        if df.empty:\par
            return df\par
\par
        display_columns = [\par
            "hold_bars",\par
            "stop_distance_points",\par
            "total_trades",\par
            "trades_per_year",\par
            "profit_factor",\par
            "average_trade",\par
            "net_pnl",\par
            "max_drawdown",\par
            "win_rate",\par
            "average_mae_points",\par
            "average_mfe_points",\par
        ]\par
\par
        available_columns = [col for col in display_columns if col in df.columns]\par
        display_df = df[available_columns].copy()\par
\par
        money_columns = ["average_trade", "net_pnl", "max_drawdown"]\par
        for col in money_columns:\par
            if col in display_df.columns:\par
                display_df[col] = display_df[col].round(2)\par
\par
        float_columns = [\par
            "stop_distance_points",\par
            "trades_per_year",\par
            "profit_factor",\par
            "win_rate",\par
            "average_mae_points",\par
            "average_mfe_points",\par
        ]\par
        for col in float_columns:\par
            if col in display_df.columns:\par
                display_df[col] = display_df[col].round(2)\par
\par
        return display_df\par
\par
    def top_results(self, n: int = 10) -> pd.DataFrame:\par
        df = self.display_dataframe()\par
        if df.empty:\par
            return df\par
        return df.head(n)\par
\par
    def save_results_csv(self, filepath: str | Path) -> Path:\par
        """\par
        Saves the full optimization results dataframe to CSV.\par
        """\par
        df = self.results_dataframe()\par
        if df.empty:\par
            raise ValueError("No optimization results to save.")\par
\par
        output_path = Path(filepath)\par
        output_path.parent.mkdir(parents=True, exist_ok=True)\par
\par
        df.to_csv(output_path, index=False)\par
        return output_path\par
