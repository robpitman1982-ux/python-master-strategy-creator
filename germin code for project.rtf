class BaseStrategy(ABC):\par
    """\par
    Base class for all strategies.\par
    """\par
\par
    name: str = "BaseStrategy"\par
    direction: str = "LONG_ONLY"\par
    hold_bars: int = 3\par
    stop_distance_points: float = 10.0\par
\par
    @abstractmethod\par
    def generate_signal(self, data: pd.DataFrame, i: int) -> int:\par
        raise NotImplementedError\par
