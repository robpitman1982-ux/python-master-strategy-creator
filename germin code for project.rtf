class MomentumFilter(BaseFilter):\par
    """\par
    Current close must be above close N bars ago.\par
    """\par
\par
    name = "MomentumFilter"\par
\par
    def __init__(self, lookback: int = 10):\par
        self.lookback = lookback\par
\par
    def passes(self, data: pd.DataFrame, i: int) -> bool:\par
        if i < self.lookback:\par
            return False\par
\par
        diff_col = f"mom_diff_\{self.lookback\}"\par
\par
        if diff_col in data.columns:\par
            mom_value = data.iloc[i][diff_col]\par
            if pd.isna(mom_value):\par
                return False\par
            return bool(mom_value > 0)\par
\par
        close_series = data["close"]\par
        current_close = close_series.iloc[i]\par
        past_close = close_series.iloc[i - self.lookback]\par
\par
        return bool(current_close > past_close)\par
